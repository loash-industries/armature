# =============================================================================
# Armature Local Dev — Docker Compose Environment
# =============================================================================
# Copy to docker/.env and adjust as needed:
#   cp docker/.env.example docker/.env
# =============================================================================

# --- Sui Localnet -----------------------------------------------------------
# The sui-localnet service runs inside Docker; these are internal defaults.
SUI_RPC_URL=http://sui-localnet:9000
SUI_FAUCET_URL=http://sui-localnet:9123

# --- World Contracts ---------------------------------------------------------
# Git ref to checkout for evefrontier/world-contracts (tag, branch, or commit)
WORLD_CONTRACTS_REF=main

# Governor private key — leave empty to auto-generate one on first run.
# Format: suiprivkey1... (base64-encoded ed25519 key)
GOVERNOR_PRIVATE_KEY=

# Fuel / energy / gate configuration (world-contracts defaults)
FUEL_TYPE_IDS=78437,78515,78516,84868,88319,88335
FUEL_EFFICIENCIES=90,80,40,40,15,10
ASSEMBLY_TYPE_IDS=77917,84556,84955,87119,87120,88063,88064,88067,88068,88069,88070,88071,88082,88083,90184,91978,92279,92401,92404
ENERGY_REQUIRED_VALUES=500,10,950,50,250,100,200,100,200,100,200,300,50,100,1,100,10,20,40
GATE_TYPE_IDS=88086,84955
MAX_DISTANCES=520340175991902420,1040680351983804840
TENANT=dev

# --- Postgres (Armature Indexer) ---------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgrespw
POSTGRES_DB=armature
POSTGRES_PORT=5432

# --- UI Dev ------------------------------------------------------------------
# Overridden automatically by the deploy pipeline; leave blank here.
VITE_NETWORK=localnet
VITE_PACKAGE_ID=
VITE_PROPOSALS_PACKAGE_ID=
