# Armature UI — localnet environment
# Copy to .env.local and fill in values, or run the setup script:
#
# Usage:
#   cp .env.local.example .env.local
#   # OR run the setup script which generates it automatically:
#   node ../scripts/localnet-setup.mjs

# Network (localnet | devnet | testnet | mainnet)
VITE_NETWORK=localnet

# Package IDs — set after publishing to localnet
# With --with-unpublished-dependencies, both packages share a single ID
VITE_PACKAGE_ID=0x...
VITE_PROPOSALS_PACKAGE_ID=0x...

# Test wallets — suiprivkey1q... or mnemonic format (up to 10)
# Used by WalletSignerProvider for localnet signing without browser wallet
VITE_WALLET_KEY_1=suiprivkey1q...
VITE_WALLET_MNEMONIC_2=word1 word2 word3 ...
VITE_WALLET_MNEMONIC_3=word1 word2 word3 ...

# Test DAO object IDs (optional — for quick navigation)
VITE_TEST_DAO_ID=0x...
VITE_TEST_TREASURY_ID=0x...
VITE_TEST_CAP_VAULT_ID=0x...
VITE_TEST_CHARTER_ID=0x...
VITE_TEST_FREEZE_ID=0x...
